{
  "version": "1.0",
  "swabbing_time": 20,
  "overconfidence": {
    "enabled": true,
    "gates": {
      "untested-code.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "test_dirs": [
          "tests"
        ],
        "timeout": 300
      },
      "coverage-gaps.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 80
      },
      "missing-annotations.py": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "strict_typing": true,
        "include_dirs": []
