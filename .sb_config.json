      "sloppy-formatting.js": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "npm_install_flags": []
      },
      "sloppy-frontend.js": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
