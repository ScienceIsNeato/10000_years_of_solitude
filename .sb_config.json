      "string-duplication.py": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 2,
        "min_file_count": 1,
        "min_length": 8,
        "min_words": 3,
        "include_patterns": [
          "**/*.py"
        ],
        "ignore_patterns": [
          "**/node_modules/**",
          "**/.venv/**",
          "**/venv/**",
          "**/__pycache__/**",
          "**/.git/**",
          "**/*.egg-info/**",
          "**/test_*",
          "**/tests/**",
          "**/conftest.py"
