      "type-blindness.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "strict": true
      },
      "untested-code.js": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "test_command": "npm test"
      },
      "coverage-gaps.js": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "threshold": 80
      },
      "type-blindness.js": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
