      "bogus-tests.py": {
        "enabled": true,
        "auto_fix": false,
        "config_file_path": null,
        "test_dirs": [
          "tests"
        ],
        "exclude_patterns": [
          "conftest.py"
        ],
        "min_test_statements": 1,
        "short_test_severity": "fail"
      },
      "debugger-artifacts": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "exclude_dirs": [],
