      "vulnerability-blindness.py": {
        "enabled": false,
        "auto_fix": false,
        "config_file_path": null,
        "scanners": [
          "bandit",
          "semgrep",
          "detect-secrets"
        ],
        "exclude_dirs": [
          "venv",
          ".venv",
          "node_modules",
          "cursor-rules",
          "archives",
          "logs",
          "tests",
          "*/.venv",
          "*/venv"
        ],
        "bandit_config_file": null
